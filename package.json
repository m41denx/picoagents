{
  "name": "picoagents",
  "version": "0.3.0",
  "description": "Bun + AI SDK CLI: planner → approved plan → orchestrator with parallel subagents, skills (.mdc), and OpenAI-compatible backends.",
  "license": "AGPL-3.0",
  "author": "M41den (https://github.com/m41denx)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m41denx/picoagents.git"
  },
  "homepage": "https://github.com/m41denx/picoagents#readme",
  "bugs": {
    "url": "https://github.com/m41denx/picoagents/issues"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "bun",
    "cli",
    "lm-studio",
    "openai",
    "orchestrator",
    "planner",
    "subagents",
    "agents"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "picoagents": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/subagent.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts",
    "smoke": "bun run src/smoke.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck",
    "build": "bun build --compile ./src/cli.ts --outfile ./dist/picoagents"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.60",
    "axios": "^1.13.2",
    "ai": "^6.0.175",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "react-devtools-core": "^6",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5"
  }
}
